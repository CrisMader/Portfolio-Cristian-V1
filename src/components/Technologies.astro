---
import { technologies, categoryLabels } from '../data/technologies';

// Agrupar tecnologías por categoría
const grouped = technologies.reduce(
  (acc, tech) => {
    if (!acc[tech.category]) acc[tech.category] = [];
    acc[tech.category].push(tech);
    return acc;
  },
  {} as Record<string, typeof technologies>
);
---

<section id="tecnologias" class="section-inner">
  <!-- Encabezado de sección -->
  <div class="flex items-center justify-between mb-16">
    <h2 class="text-[#E2E3E4] text-lg font-mono">Tecnologías</h2>
    <div class="flex-1 h-px bg-[#E2E3E4] ml-8 opacity-30"></div>
  </div>

  <!-- Grid de tecnologías por categoría -->
  <div class="space-y-12">
    {Object.entries(grouped).map(([category, techs]) => (
      <div>
        <h3 class="text-[#49EB78] text-sm font-mono mb-6">
          {categoryLabels[category as keyof typeof categoryLabels]}
        </h3>
        <div class="flex flex-wrap gap-8 items-center">
          {techs.map((tech) => (
            <div class="flex flex-col items-center gap-2 group">
              <div class="w-16 h-16 flex items-center justify-center">
                {/* TODO: Añadir imágenes de iconos reales */}
                <span class="text-[#E2E3E4] text-xs text-center group-hover:text-[#49EB78] transition-colors">
                  {tech.name}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
