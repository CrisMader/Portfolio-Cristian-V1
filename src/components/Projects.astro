---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section id="proyectos" class="section-inner" style="min-height: unset;">
  <div class="flex items-center justify-between mb-16">
    <h2 class="text-[#E2E3E4] text-lg" style="font-family: 'LaNord', sans-serif; font-weight: 700;">Proyectos</h2>
    <div class="flex-1 h-px bg-[#E2E3E4] ml-8 opacity-30"></div>
  </div>

  <div class="space-y-16">
    {projects.map((project) => (
      <ProjectCard project={project} />
    ))}

    {projects.length === 0 && (
      <p class="text-[#E2E3E4] opacity-50 text-sm">Próximamente...</p>
    )}
  </div>
</section>
